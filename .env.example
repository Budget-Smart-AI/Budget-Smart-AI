# BudgetSmart AI Environment Variables
# Copy to .env and fill in your values

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/budgetsmart

# Server
PORT=3000
NODE_ENV=production
SESSION_SECRET=your-session-secret-here-change-this
APP_URL=http://localhost:3000
BASE_URL=http://localhost:3000

# AI Services
DEEPSEEK_API_KEY=your-deepseek-api-key-here
OPENAI_API_KEY=your-openai-api-key-here  # Fallback only

# Email (Postmark)
POSTMARK_SERVER=smtp.postmarkapp.com
POSTMARK_PORT=587
POSTMARK_USERNAME=your-postmark-username
POSTMARK_PASSWORD=your-postmark-password
ALERT_EMAIL_FROM=alerts@budgetsmart.ai
ALERT_EMAIL_TO=admin@budgetsmart.ai

# Banking APIs
PLAID_CLIENT_ID=your-plaid-client-id
PLAID_SECRET=your-plaid-secret
MX_CLIENT_ID=your-mx-client-id
MX_API_KEY=your-mx-api-key

# Stripe Payments
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret

# Google OAuth
GOOGLE_OAUTH_CLIENT_ID=your-google-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-google-client-secret

# Alpha Vantage (Stock data)
ALPHA_ADVANTAGE_API=your-alpha-vantage-api-key

# Admin Access
USER_PASSWORD=admin-password-here-change-this