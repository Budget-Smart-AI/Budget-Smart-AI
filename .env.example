# BudgetSmart AI — Environment Variable Reference
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env for LOCAL DEVELOPMENT only. Fill in real values.
# .env is gitignored and MUST NEVER be committed to version control.
#
# For Railway (production/staging): set variables in the Railway dashboard
#   https://docs.railway.app/guides/variables
# For GitHub Actions: set variables as repository secrets
#   https://docs.github.com/en/actions/security-guides/encrypted-secrets
#
# SOC 2 / NIST REQUIREMENT: All variables listed here are REQUIRED to be set
# via the Railway dashboard. No default values exist for security-sensitive
# variables. The application will refuse to create admin/demo users and will
# log clear errors for any missing configuration.
# ─────────────────────────────────────────────────────────────────────────────

# ── Encryption ────────────────────────────────────────────────────────────────
# FIELD_ENCRYPTION_KEY — 64 hex characters (= 32 bytes / 256 bits) used for
#   AES-256-GCM field-level encryption of sensitive data (Plaid tokens, etc.).
#   The server will refuse to start if this is missing or not exactly 64 chars.
#   Generate with:  openssl rand -hex 32
#   Example:        a3f7...64hexchars...b2e9
FIELD_ENCRYPTION_KEY=<generate: openssl rand -hex 32>

# ── Application ───────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
SESSION_SECRET=<random-64-byte-base64-value — generate with: openssl rand -base64 64>
APP_URL=https://app.budgetsmart.io
BASE_URL=https://budgetsmart.io
MAIN_DOMAIN=budgetsmart.io

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Admin / Demo User Setup (REQUIRED — no defaults) ─────────────────────────
#
# ADMIN_USERNAME — the login username for the built-in admin account.
#   Choose any alphanumeric string (e.g. "mahabir" or "admin").
#   You pick this yourself; there is no generation command needed.
#   Example: ADMIN_USERNAME=mahabir
#
# USER_PASSWORD — the password for the admin account above.
#   Choose (or generate) any strong password — minimum 12 characters.
#   Generate with:  openssl rand -base64 18
#   Output is ~24 characters, e.g.: Xk9mR2bqN5pLyTz3Wv==
#
# DEMO_PASSWORD — the password for the read-only "demo" account
#   (username: "demo").  This account comes pre-loaded with sample data so
#   visitors can try the app without registering.  The password is only used
#   internally; end-users don't need to know it.
#   Generate with:  openssl rand -base64 18
#   Output is ~24 characters, e.g.: Pz3nW7vYcT1sQmK8Jx==
#
# Generate USER_PASSWORD and DEMO_PASSWORD in one command (run twice for two values):
#   openssl rand -base64 18
ADMIN_USERNAME=<choose-your-admin-username>
USER_PASSWORD=<generate: openssl rand -base64 18>
DEMO_PASSWORD=<generate: openssl rand -base64 18>

# ── Email (Postmark) ──────────────────────────────────────────────────────────
# Railway blocks outbound SMTP, so we use Postmark's HTTP API instead.
# POSTMARK_USERNAME must be set to your Postmark Server API Token.
# POSTMARK_SERVER and POSTMARK_PORT are no longer used and can be omitted.
#
# IMPORTANT: ALERT_EMAIL_FROM must be an address that is a verified Sender
# Signature (or belongs to a verified domain) on your Postmark account.
# To verify a sender, go to: https://account.postmarkapp.com/signature_domains
# Using an unverified address will cause all outbound emails to fail with a
# 422 "not a Sender Signature" error from Postmark.
POSTMARK_USERNAME=<postmark-server-token>
ALERT_EMAIL_FROM=support@budgetsmart.io
ALERT_EMAIL_TO=admin@budgetsmart.io
SUPPORT_EMAIL=support@budgetsmart.io
SALES_EMAIL=sales@budgetsmart.io

# ── AI Services ───────────────────────────────────────────────────────────────
DEEPSEEK_API_KEY=<deepseek-api-key>
OPENAI_API_KEY=<openai-api-key>
ANTHROPIC_API_KEY=<anthropic-api-key>
CLAUDE_API_KEY=<anthropic-api-key>    # Alias for ANTHROPIC_API_KEY

# ── Plaid ─────────────────────────────────────────────────────────────────────
PLAID_CLIENT_ID=<plaid-client-id>
PLAID_SECRET=<plaid-secret>

# ── MX (Atrium) ───────────────────────────────────────────────────────────────
MX_CLIENT_ID=<mx-client-id>
MX_API_KEY=<mx-api-key>
MX_BASIC_AUTH_VALUE=<base64(client-id:api-key)>
# Override the API base URL if needed; defaults to production when NODE_ENV=production
# MX_API_BASE_URL=https://api.mx.com

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=<stripe-secret-key>
STRIPE_WEBHOOK_SECRET=<stripe-webhook-secret>

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_OAUTH_CLIENT_ID=<google-client-id>
GOOGLE_OAUTH_CLIENT_SECRET=<google-client-secret>

# ── Alpha Vantage (Stock data) ────────────────────────────────────────────────
ALPHA_ADVANTAGE_API=<alpha-vantage-api-key>

# ── Cloudflare R2 Storage (receipt uploads) ───────────────────────────────────
R2_ACCESS_KEY_ID=<r2-access-key-id>
R2_SECRET_ACCESS_KEY=<r2-secret-access-key>
R2_TOKEN_VALUE=<r2-secret-access-key>    # Fallback alias
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_BUCKET_NAME=<bucket-name>
R2_PUBLIC_URL=                           # Optional: custom public domain for R2 assets

# ── AWS KMS (encryption at rest for Plaid access tokens) ─────────────────────
# Create a Symmetric KMS key in AWS → Key Management Service, then paste the
# ARN below. Grant the IAM user/role kms:Encrypt + kms:Decrypt on this key.
AWS_REGION=us-east-1
AWS_KMS_KEY_ID=arn:aws:kms:<region>:<account-id>:key/<key-id>
AWS_ACCESS_KEY_ID=<aws-access-key-id>
AWS_SECRET_ACCESS_KEY=<aws-secret-access-key>
